{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noImplicitAny": true,
    "lib": ["ES2022"],
    "noEmit": true,
    "skipLibCheck": true,
    "rootDir": ".."
  },
  "include": ["src/**/*.ts", "../src/**/*.ts"]
}
